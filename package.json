{
  "name": "stratpilot",
  "private": true,
  "scripts": {
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "cd apps/api && ../../.venv/bin/uvicorn main:app --reload --host 0.0.0.0 --port 8000",
    "dev:web": "cd apps/web && next dev --port 3000",
    "install:all": "python3 -m venv .venv && .venv/bin/python -m pip install --upgrade pip && .venv/bin/pip install -r apps/api/requirements.txt && cd apps/web && npm install",
    "smoke": "PYTHONPATH=apps/api .venv/bin/python scripts/smoke_api.py",
    "build:web": "cd apps/web && npm run build"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
